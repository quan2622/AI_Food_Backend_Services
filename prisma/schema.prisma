// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  genderCode   String?
  avatarUrl    String?
  fullName     String
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  birthOfDate  DateTime?
  isAdmin      Boolean  @default(false)
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userProfile  UserProfile?
  nutritionGoals NutritionGoal[]

  dailyLogs    DailyLog[]

  @@map("users")
}

model UserProfile {
  id            Int      @id @default(autoincrement())
  allergies     String[]
  age           Int
  height        Float
  weight        Float
  bmi           Float
  bmr           Float
  tdee          Float
  gender        String?
  activityLevel String?
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_profiles")
}

model NutritionGoal {
  id                    Int      @id @default(autoincrement())
  goalType              String
  targetCaloriesPerDay  Float
  targetProteinPerDay   Float    @default(0)
  targetCarbsPerDay     Float    @default(0)
  targetFatPerDay       Float    @default(0)
  startDate             DateTime
  endDate               DateTime
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("nutrition_goals")
}

model AllCode {
  id          Int      @id @default(autoincrement())
  keyMap      String   @unique
  type        String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("all_codes")
}

model Food {
  id          Int        @id @default(autoincrement())
  foodName    String
  description String?
  categoryId  Int?
  foodCategory FoodCategory? @relation(fields: [categoryId], references: [id])
  foodType    String        @default("INGREDIENT")
  imageUrl    String?
  protein     Float         @default(0)
  carbs       Float         @default(0)
  fat         Float         @default(0)
  fiber       Float         @default(0)
  calories    Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  mealItems   MealItem[]

  nutritions       FoodNutrition[]
  dishIngredients  DishIngredient[] @relation("DishHasIngredients")
  usedAsIngredient DishIngredient[] @relation("IngredientUsedInDish")

  @@map("foods")
}

model FoodCategory {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  parentId    Int?
  parent      FoodCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    FoodCategory[] @relation("CategoryTree")
  foods       Food[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("food_categories")
}

model NutritionComponent {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  unit      String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  values    FoodNutritionValue[]

  @@map("nutrition_components")
}

model FoodNutrition {
  id            Int                  @id @default(autoincrement())
  servingSize   Float
  servingUnit   String               @default("g")
  source        String               @default("MANUAL")
  isCalculated  Boolean              @default(false)
  foodId        Int
  food          Food                 @relation(fields: [foodId], references: [id], onDelete: Cascade)
  values        FoodNutritionValue[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("food_nutritions")
}

model FoodNutritionValue {
  id          Int                @id @default(autoincrement())
  value       Float
  nutritionId Int
  nutrition   FoodNutrition      @relation(fields: [nutritionId], references: [id], onDelete: Cascade)
  componentId Int
  component   NutritionComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([nutritionId, componentId])
  @@map("food_nutrition_values")
}

model DishIngredient {
  id             Int      @id @default(autoincrement())
  quantityGrams  Float
  dishId         Int
  dish           Food     @relation("DishHasIngredients", fields: [dishId], references: [id], onDelete: Cascade)
  ingredientId   Int
  ingredient     Food     @relation("IngredientUsedInDish", fields: [ingredientId], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([dishId, ingredientId])
  @@map("dish_ingredients")
}

model Meal {
  id            Int         @id @default(autoincrement())
  mealType      String
  mealDateTime  DateTime
  dailyLogId    Int
  dailyLog      DailyLog    @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  mealItems     MealItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("meals")
}

model MealItem {
  id         Int         @id @default(autoincrement())
  quantity   Float
  calories   Float       @default(0)
  protein    Float       @default(0)
  carbs      Float       @default(0)
  fat        Float       @default(0)
  fiber      Float       @default(0)
  foodId     Int
  food       Food        @relation(fields: [foodId], references: [id], onDelete: Restrict)
  mealId     Int
  meal       Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodImages FoodImage[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("meal_items")
}

model FoodImage {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  fileName   String?
  mimeType   String?
  fileSize   Int?
  uploadedAt DateTime @default(now())
  mealItemId Int
  mealItem   MealItem @relation(fields: [mealItemId], references: [id], onDelete: Cascade)

  @@map("food_images")
}

model DailyLog {
  id             Int      @id @default(autoincrement())
  logDate        DateTime @db.Date
  totalCalories  Float    @default(0)
  totalProtein   Float    @default(0)
  totalCarbs     Float    @default(0)
  totalFat       Float    @default(0)
  totalFiber     Float    @default(0)
  targetCalories Float    @default(0)
  targetProtein  Float    @default(0)
  targetCarbs    Float    @default(0)
  targetFat      Float    @default(0)
  targetFiber    Float    @default(0)
  status         String   @default("BELOW")
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals          Meal[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, logDate])
  @@map("daily_logs")
}