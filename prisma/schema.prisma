// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  genderCode   String?
  avatarUrl    String?
  fullName     String
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  birthOfDate  DateTime?
  isAdmin      Boolean  @default(false)
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userProfile  UserProfile?
  nutritionGoals NutritionGoal[]
  meals        Meal[]

  @@map("users")
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  allergies String[]
  age       Int
  height    Float
  weight    Float
  bmi       Float
  bmr       Float
  tdee      Float
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

model NutritionGoal {
  id                    Int      @id @default(autoincrement())
  goalType              String
  targetCaloriesPerDay  Float
  startDate             DateTime
  endDate               DateTime
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("nutrition_goals")
}

model AllCode {
  id          Int      @id @default(autoincrement())
  keyMap      String   @unique
  type        String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("all_codes")
}

model Food {
  id          Int        @id @default(autoincrement())
  foodName    String
  description String?
  category    String
  imageUrl    String?
  protein     Float      @default(0)
  carbs       Float      @default(0)
  fat         Float      @default(0)
  calories    Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mealItems   MealItem[]

  @@map("foods")
}

model Meal {
  id            Int         @id @default(autoincrement())
  mealType      String
  mealDateTime  DateTime
  totalCalories Float       @default(0)
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems     MealItem[]
  foodImages    FoodImage[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("meals")
}

model MealItem {
  id       Int   @id @default(autoincrement())
  quantity Float
  calories Float @default(0)
  protein  Float @default(0)
  carbs    Float @default(0)
  fat      Float @default(0)
  foodId   Int
  food     Food  @relation(fields: [foodId], references: [id], onDelete: Restrict)
  mealId   Int
  meal     Meal  @relation(fields: [mealId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meal_items")
}

model FoodImage {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  fileName   String?
  mimeType   String?
  fileSize   Int?
  uploadedAt DateTime @default(now())
  mealId     Int
  meal       Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("food_images")
}